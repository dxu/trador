{
  "name": "trador",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"bun run --filter @trador/api dev\" \"bun run --filter @trador/web dev\"",
    "dev:api": "bun run --filter @trador/api dev",
    "dev:web": "bun run --filter @trador/web dev",
    "build": "bun run --filter @trador/api build && bun run --filter @trador/web build",
    "build:api": "bun run --filter @trador/api build",
    "build:web": "bun run --filter @trador/web build",
    "start": "bun run --filter @trador/api start",
    "db:generate": "bun run --filter @trador/api db:generate",
    "db:migrate": "bun run --filter @trador/api db:migrate",
    "db:push": "bun run --filter @trador/api db:push"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "typescript": "^5.3.3"
  }
}
