# =============================================================================
# TRADOR - Environment Configuration
# =============================================================================
# Copy this file to packages/api/.env and fill in your values
# =============================================================================

# PostgreSQL connection string
DATABASE_URL=postgresql://localhost:5432/trador

# Password for the web dashboard
APP_PASSWORD=changeme

# Session signing secret (auto-generated if not set)
# SESSION_SECRET=

# Enable/disable automatic data ingestion on startup
DATA_INGESTION_ENABLED=true

# Server port
PORT=3000
